# --------------------------------------------------------------------------
# NexusFlow environment variables
# Copy this file to `.env` for local Docker Compose usage.
# For production (Railway/Vercel/Fly), set these in your platform's secrets UI.
# --------------------------------------------------------------------------

# ───────── Postgres ─────────────────────────────────────────────────────────
POSTGRES_USER=nexusflow
POSTGRES_PASSWORD=nexusflow_dev
POSTGRES_DB=nexusflow
# Host port mapping (the container always listens on 5432 internally).
# Change to 5432 if you don't have a local Postgres running on it.
POSTGRES_HOST_PORT=5433

# ───────── API ──────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5080

# In Docker Compose, host is `postgres`. In production, paste the connection
# string from your DB provider (Railway, Neon, Supabase, etc.).
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=nexusflow;Username=nexusflow;Password=nexusflow_dev

# JWT — IMPORTANT: rotate SigningKey for prod. Must be ≥ 32 chars.
Jwt__Issuer=nexusflow
Jwt__Audience=nexusflow-web
Jwt__SigningKey=change-me-to-a-very-long-random-string-at-least-32-chars
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=14

# Comma-separated list of origins allowed to call the API. In prod set to your
# Vercel/custom domain (e.g. https://nexusflow.vercel.app,https://nexusflow.io).
Cors__AllowedOrigins=http://localhost:3000

# DataProtection keys path (DB-encrypted credentials). Mounted as a volume
# in docker-compose. On Railway/Fly this should point to a persistent disk.
DataProtection__KeysPath=/app/keys

# Hangfire dashboard (`/hangfire`):
#   • In Development: open access.
#   • In Production: protected by HTTP Basic. Set both vars or it stays locked.
Hangfire__DashboardUser=admin
Hangfire__DashboardPassword=change-me

# ───────── Web ──────────────────────────────────────────────────────────────
# Public URL the browser uses to reach the API. In prod set to your Railway/Fly
# API URL (e.g. https://nexusflow-api.up.railway.app).
NEXT_PUBLIC_API_URL=http://localhost:5080
